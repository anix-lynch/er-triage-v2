# Required for local regeneration of assessments via app/engine.py.
# In Cloud Run this is mounted from Secret Manager (anthropic-api-key:latest).
ANTHROPIC_API_KEY=sk-ant-...

# Optional — toggles RAG injection in engine.py. Default: true.
# Set to "false" to compare assessments with/without similar-case retrieval.
USE_RAG=true

# Optional — Vertex AI project + region for embeddings.
# Defaults are set in app/retrieval/embed.py; override only if your GCP setup differs.
# GCP_PROJECT_ID=your-gcp-project
# GCP_LOCATION=us-central1

# Optional fallback for embeddings if Vertex AI is unavailable.
# GEMINI_API_KEY=...
